{
  "watch": ["src"],
  "ext": "ts,json",
  "ignore": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "tests/**",
    "dist",
    "node_modules",
    "logs"
  ],
  "exec": "ts-node -r tsconfig-paths/register --project tsconfig.json src/server.ts",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": 1000
}